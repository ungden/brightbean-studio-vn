{
  "name": "Brightbean",
  "description": "Open-source social media management platform",
  "repository": "https://github.com/brightbeanxyz/brightbean-social-management",
  "keywords": ["django", "social-media", "management"],
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    },
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "addons": [
    {
      "plan": "heroku-postgresql:essential-0"
    }
  ],
  "env": {
    "SECRET_KEY": {
      "generator": "secret"
    },
    "DJANGO_SETTINGS_MODULE": {
      "value": "config.settings.production"
    },
    "ALLOWED_HOSTS": {
      "description": "Comma-separated list of allowed hostnames",
      "required": true
    },
    "APP_URL": {
      "description": "Public URL of the application (e.g., https://your-app.herokuapp.com)",
      "required": true
    },
    "STORAGE_BACKEND": {
      "description": "Storage backend: 'local' or 's3'",
      "value": "s3"
    },
    "S3_ENDPOINT_URL": {
      "description": "S3-compatible endpoint URL",
      "required": false
    },
    "S3_ACCESS_KEY_ID": {
      "description": "S3 access key",
      "required": false
    },
    "S3_SECRET_ACCESS_KEY": {
      "description": "S3 secret key",
      "required": false
    },
    "S3_BUCKET_NAME": {
      "description": "S3 bucket name",
      "required": false
    }
  },
  "scripts": {
    "postdeploy": "python manage.py migrate"
  },
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "heroku/python"
    }
  ]
}
