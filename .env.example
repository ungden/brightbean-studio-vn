# CORE
SECRET_KEY=change-me-to-a-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
APP_URL=http://localhost:8000

# DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/brightbean

# STORAGE
STORAGE_BACKEND=local
MEDIA_ROOT=/app/media
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_CUSTOM_DOMAIN=
S3_REGION_NAME=auto

# EMAIL
EMAIL_BACKEND_TYPE=smtp
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
RESEND_API_KEY=

# PLATFORM CREDENTIALS (cloud version — self-hosted uses admin UI)
PLATFORM_FACEBOOK_APP_ID=
PLATFORM_FACEBOOK_APP_SECRET=
PLATFORM_LINKEDIN_CLIENT_ID=
PLATFORM_LINKEDIN_CLIENT_SECRET=
PLATFORM_TIKTOK_CLIENT_KEY=
PLATFORM_TIKTOK_CLIENT_SECRET=
PLATFORM_GOOGLE_CLIENT_ID=
PLATFORM_GOOGLE_CLIENT_SECRET=
PLATFORM_PINTEREST_APP_ID=
PLATFORM_PINTEREST_APP_SECRET=

# AI (optional — also configurable via admin UI)
AI_OPENAI_API_KEY=
AI_OPENAI_DEFAULT_MODEL=gpt-4o
AI_ANTHROPIC_API_KEY=
AI_ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
AI_OPENROUTER_API_KEY=
AI_OPENROUTER_DEFAULT_MODEL=
AI_DEFAULT_PROVIDER=

# REDIS (optional — not required at launch)
REDIS_URL=

# INBOUND WEBHOOKS
FACEBOOK_WEBHOOK_VERIFY_TOKEN=
YOUTUBE_WEBHOOK_SECRET=

# SENTRY (optional)
SENTRY_DSN=
